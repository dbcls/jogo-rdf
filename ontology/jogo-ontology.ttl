@prefix jogo:    <http://jogo.csml.org/ontology#> .
@prefix faldo:   <http://biohackathon.org/resource/faldo#> .
@prefix gvo:     <http://genome-variation.org/resource/gvo#> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# JoGo Haplotype Ontology — たたき台 (draft)
# =============================================================================

<http://jogo.csml.org/ontology#>
    a owl:Ontology ;
    rdfs:label "JoGo Haplotype Ontology"@en ;
    dcterms:description "Ontology for the JoGo haplotype database (haplotypes at amino-acid / coding / transcript / genebody levels, their composites, variants, and population frequencies)."@en ;
    owl:versionInfo "0.1-draft" .


# =============================================================================
# Classes
# =============================================================================

# --- 遺伝子領域 -------------------------------------------------------------
jogo:GeneRegion
    a owl:Class ;
    rdfs:label "Gene Region"@en , "遺伝子領域"@ja ;
    rdfs:comment "A MANE-defined gene region for which haplotypes are catalogued (cf. maneinfo)."@en .

# --- ハプロタイプ階層 -------------------------------------------------------
jogo:Haplotype
    a owl:Class ;
    rdfs:label "Haplotype"@en , "ハプロタイプ"@ja ;
    rdfs:comment "Abstract superclass of all JoGo haplotypes."@en .

jogo:IndividualHaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:Haplotype ;
    rdfs:label "Individual Haplotype"@en , "個別ハプロタイプ"@ja ;
    rdfs:comment "A haplotype defined and numbered independently within a single sequence level (A / C / T / G)."@en .

jogo:CompositeHaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:Haplotype ;
    rdfs:label "Composite Haplotype"@en , "複合ハプロタイプ"@ja ;
    rdfs:comment "A haplotype representing an observed combination of individual haplotypes across levels (AC / ACT / ACTG)."@en .

# 個別レベル (A / C / T / G)
jogo:AHaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:IndividualHaplotype ;
    rdfs:label "Amino acid sequence level haplotype"@en , "アミノ酸配列レベルハプロタイプ"@ja ;
    skos:altLabel "A"@en ;
    rdfs:comment "Amino-acid-sequence-level haplotype: a distinct protein (amino acid) sequence of the gene. Source: ahaplotypesummary (ahapid)."@en .

jogo:CHaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:IndividualHaplotype ;
    rdfs:label "Coding sequence (CDS) level haplotype"@en , "コーディング配列(CDS)レベルハプロタイプ"@ja ;
    skos:altLabel "C"@en ;
    rdfs:comment "Coding(CDS)-sequence-level haplotype: a distinct coding nucleotide sequence. Source: chaplotypesummary (chapid)."@en .

jogo:THaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:IndividualHaplotype ;
    rdfs:label "Transcript level haplotype"@en , "転写産物レベルハプロタイプ"@ja ;
    skos:altLabel "T"@en ;
    rdfs:comment "Transcript-level haplotype: a distinct transcript (mRNA incl. UTR) sequence. Source: thaplotypesummary (thapid)."@en .

jogo:GHaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:IndividualHaplotype ;
    rdfs:label "Genebody level haplotype"@en , "遺伝子本体レベルハプロタイプ"@ja ;
    skos:altLabel "G"@en ;
    rdfs:comment "Genebody-level haplotype: a distinct gene-body sequence (incl. introns). Source: ghaplotypesummary (ghapid)."@en .

jogo:UHaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:IndividualHaplotype ;
    rdfs:label "Upstream level haplotype"@en , "上流レベルハプロタイプ"@ja ;
    skos:altLabel "U"@en ;
    rdfs:comment "Upstream flanking-region haplotype. Source: regions/<rn>/flanks upstream (uid), aggregated per uid."@en .

jogo:DHaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:IndividualHaplotype ;
    rdfs:label "Downstream level haplotype"@en , "下流レベルハプロタイプ"@ja ;
    skos:altLabel "D"@en ;
    rdfs:comment "Downstream flanking-region haplotype. Source: regions/<rn>/flanks downstream (did), aggregated per did."@en .

# 複合レベル (AC / ACT / ACTG) — 構成レベルを " + " で連結し累積を明示
jogo:ACHaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:CompositeHaplotype ;
    rdfs:label "AC level haplotype"@en , "AC レベルハプロタイプ"@ja ;
    skos:altLabel "AC"@en ;
    rdfs:comment "A composite of an A and a C haplotype. Source: achaplotypesummary (achapid)."@en .

jogo:ACTHaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:CompositeHaplotype ;
    rdfs:label "ACT level haplotype"@en , "ACT レベルハプロタイプ"@ja ;
    skos:altLabel "ACT"@en ;
    rdfs:comment "A composite of A, C and T haplotypes. Source: acthaplotypesummary (acthapid)."@en .

jogo:ACTGHaplotype
    a owl:Class ;
    rdfs:subClassOf jogo:CompositeHaplotype ;
    rdfs:label "ACTG level haplotype"@en , "ACTG レベルハプロタイプ"@ja ;
    skos:altLabel "ACTG"@en ;
    rdfs:comment "A composite of A, C, T and G haplotypes; the full sample-level haplotype. Source: actghaplotypesummary (actghapid)."@en .

# --- 集団頻度 ---------------------------------------------------------------
jogo:PopulationFrequency
    a owl:Class ;
    rdfs:label "Population Frequency"@en , "集団頻度"@ja ;
    rdfs:comment "Observed count/frequency of a haplotype within a given population."@en .

jogo:Population
    a owl:Class ;
    rdfs:label "Population"@en , "集団"@ja ;
    rdfs:comment "A population (e.g. 1000 Genomes population such as JPT)."@en .

jogo:SuperPopulation
    a owl:Class ;
    rdfs:subClassOf jogo:Population ;
    rdfs:label "Super Population"@en , "スーパー集団"@ja ;
    rdfs:comment "A super-population grouping several populations (e.g. EAS)."@en .

jogo:Sample
    a owl:Class ;
    rdfs:label "Sample"@en , "サンプル"@ja ;
    rdfs:comment "An individual genome sample (1000 Genomes / JoGo cohort)."@en .

jogo:SampleHaplotype
    a owl:Class ;
    rdfs:label "Sample Haplotype"@en , "サンプルハプロタイプ"@ja ;
    rdfs:comment "One phased haplotype (hp1/hp2) of a sample within a gene region. Identifier is gene-region scoped, e.g. ALDH2:HG02074.hp1."@en .

jogo:Variant
    a owl:Class ;
    rdfs:label "Variant"@en , "バリアント"@ja ;
    rdfs:comment "A gene-context variant record carrying gene/transcript-specific allele frequency and snpEff annotation. Linked via rdfs:seeAlso to a canonical, gene-agnostic genomic variant (a gvo:SNV holding the shared class/ref/alt/location)."@en .


# =============================================================================
# Object Properties
# =============================================================================

# --- 遺伝子領域 / 複合 → 個別ハプロタイプ -----------------------------------
# domain は GeneRegion(一覧) と CompositeHaplotype(構成要素) の和
jogo:aHaplotype
    a owl:ObjectProperty ;
    rdfs:label "a haplotype"@en ;
    rdfs:comment "Relates a gene region (its A-haplotype catalogue) or a composite haplotype (its A component) to an A haplotype."@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( jogo:GeneRegion jogo:CompositeHaplotype ) ] ;
    rdfs:range jogo:AHaplotype .

jogo:cHaplotype
    a owl:ObjectProperty ;
    rdfs:label "c haplotype"@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( jogo:GeneRegion jogo:CompositeHaplotype ) ] ;
    rdfs:range jogo:CHaplotype .

jogo:tHaplotype
    a owl:ObjectProperty ;
    rdfs:label "t haplotype"@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( jogo:GeneRegion jogo:CompositeHaplotype ) ] ;
    rdfs:range jogo:THaplotype .

jogo:gHaplotype
    a owl:ObjectProperty ;
    rdfs:label "g haplotype"@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( jogo:GeneRegion jogo:CompositeHaplotype ) ] ;
    rdfs:range jogo:GHaplotype .

# --- 遺伝子領域 → 複合ハプロタイプ ------------------------------------------
jogo:acHaplotype
    a owl:ObjectProperty ;
    rdfs:label "ac haplotype"@en ;
    rdfs:domain jogo:GeneRegion ;
    rdfs:range jogo:ACHaplotype .

jogo:actHaplotype
    a owl:ObjectProperty ;
    rdfs:label "act haplotype"@en ;
    rdfs:domain jogo:GeneRegion ;
    rdfs:range jogo:ACTHaplotype .

jogo:actgHaplotype
    a owl:ObjectProperty ;
    rdfs:label "actg haplotype"@en ;
    rdfs:domain jogo:GeneRegion ;
    rdfs:range jogo:ACTGHaplotype .

jogo:uHaplotype
    a owl:ObjectProperty ;
    rdfs:label "u haplotype"@en ;
    rdfs:domain jogo:GeneRegion ;
    rdfs:range jogo:UHaplotype .

jogo:dHaplotype
    a owl:ObjectProperty ;
    rdfs:label "d haplotype"@en ;
    rdfs:domain jogo:GeneRegion ;
    rdfs:range jogo:DHaplotype .

# --- ハプロタイプ ↔ サンプル -----------------------------------------------
jogo:hasSampleHaplotype
    a owl:ObjectProperty ;
    rdfs:label "has sample haplotype"@en ;
    rdfs:comment "A phased sample haplotype (hp1/hp2) that carries this haplotype in the gene region."@en ;
    rdfs:domain jogo:Haplotype ;
    rdfs:range jogo:SampleHaplotype .

jogo:sample
    a owl:ObjectProperty ;
    rdfs:label "sample"@en ;
    rdfs:comment "The sample (individual) that this sample haplotype belongs to."@en ;
    rdfs:domain jogo:SampleHaplotype ;
    rdfs:range jogo:Sample .

# --- ハプロタイプ → バリアント / 頻度 ---------------------------------------
jogo:hasVariant
    a owl:ObjectProperty ;
    rdfs:label "has variant"@en ;
    rdfs:comment "A (gene-context) variant carried by this haplotype."@en ;
    rdfs:domain jogo:Haplotype ;
    rdfs:range jogo:Variant .

# 遺伝子別レコード(jogo:Variant) ↔ 正準ゲノム変異(gvo:Variation) の双方向リンク
jogo:genomicVariant
    a owl:ObjectProperty ;
    rdfs:label "genomic variant"@en ;
    rdfs:comment "Links a gene-context variant record to its canonical, gene-agnostic genomic variant (a GVO Variation)."@en ;
    rdfs:domain jogo:Variant ;
    rdfs:range gvo:Variation ;
    owl:inverseOf jogo:hasGeneVariant .

jogo:hasGeneVariant
    a owl:ObjectProperty ;
    rdfs:label "has gene variant"@en ;
    rdfs:comment "Links a canonical genomic variant to the gene-context variant records describing it (one per gene/region)."@en ;
    rdfs:domain gvo:Variation ;
    rdfs:range jogo:Variant .

jogo:frequency
    a owl:ObjectProperty ;
    rdfs:label "frequency"@en ;
    rdfs:comment "A per-population frequency observation of this haplotype."@en ;
    rdfs:domain jogo:Haplotype ;
    rdfs:range jogo:PopulationFrequency .

jogo:population
    a owl:ObjectProperty ;
    rdfs:label "population"@en ;
    rdfs:comment "Relates a population-frequency observation or a sample to a population."@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( jogo:PopulationFrequency jogo:Sample ) ] ;
    rdfs:range jogo:Population .

jogo:group
    a owl:DatatypeProperty ;
    rdfs:label "group"@en ;
    rdfs:comment "Name of a JoGo cohort/group the sample belongs to (e.g. 1KG_ONT_VIENNA, JoGo_JPT_HPRC)."@en ;
    rdfs:domain jogo:Sample ;
    rdfs:range xsd:string .

jogo:superPopulation
    a owl:ObjectProperty ;
    rdfs:label "super population"@en ;
    rdfs:comment "Relates a population to the 1000 Genomes super-population it belongs to."@en ;
    rdfs:domain jogo:Population ;
    rdfs:range jogo:SuperPopulation .

jogo:sampleSize
    a owl:DatatypeProperty ;
    rdfs:label "sample size"@en ;
    rdfs:comment "Number of JoGo samples (individuals) used from this population."@en ;
    rdfs:domain jogo:Population ;
    rdfs:range xsd:integer .


# =============================================================================
# Datatype Properties
# =============================================================================

# --- 遺伝子領域 -------------------------------------------------------------
jogo:regionName
    a owl:DatatypeProperty ;
    rdfs:label "region name"@en ;
    rdfs:domain jogo:GeneRegion ;
    rdfs:range xsd:string .

jogo:maneStatus
    a owl:DatatypeProperty ;
    rdfs:label "MANE status"@en ;
    rdfs:domain jogo:GeneRegion ;
    rdfs:range xsd:string .

jogo:maneVersion
    a owl:DatatypeProperty ;
    rdfs:label "MANE version"@en ;
    rdfs:domain jogo:GeneRegion ;
    rdfs:range xsd:string .

# --- ハプロタイプ共通 -------------------------------------------------------
jogo:sequenceLength
    a owl:DatatypeProperty ;
    rdfs:label "sequence length"@en ;
    rdfs:comment "Sequence length of the haplotype (A: amino-acid residues, C: CDS nt, T: transcript nt). Not present for G."@en ;
    rdfs:domain jogo:Haplotype ;
    rdfs:range xsd:integer .

jogo:totalCount
    a owl:DatatypeProperty ;
    rdfs:label "total count"@en ;
    rdfs:comment "Total number of observed haplotype copies (column 'total')."@en ;
    rdfs:domain jogo:Haplotype ;
    rdfs:range xsd:integer .

jogo:isGRCh38Reference
    a owl:DatatypeProperty ;
    rdfs:label "is GRCh38 reference"@en ;
    rdfs:comment "Whether this haplotype matches the GRCh38 (p0) reference (source: 1/0)."@en ;
    rdfs:domain jogo:Haplotype ;
    rdfs:range xsd:boolean .

jogo:isCHM13Reference
    a owl:DatatypeProperty ;
    rdfs:label "is CHM13 reference"@en ;
    rdfs:comment "Whether this haplotype matches the CHM13 (v2) reference (source: 1/0)."@en ;
    rdfs:domain jogo:Haplotype ;
    rdfs:range xsd:boolean .

jogo:isMANEReference
    a owl:DatatypeProperty ;
    rdfs:label "is MANE reference"@en ;
    rdfs:comment "Whether this haplotype matches the MANE reference (source: 1/0)."@en ;
    rdfs:domain jogo:Haplotype ;
    rdfs:range xsd:boolean .

# --- 頻度 / バリアント (対立遺伝子) -----------------------------------------
jogo:alleleCount
    a owl:DatatypeProperty ;
    rdfs:label "allele count"@en ;
    rdfs:comment "Allele count (AC). On PopulationFrequency: count within the population; on a variant: overall AC."@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( jogo:PopulationFrequency jogo:Variant ) ] ;
    rdfs:range xsd:integer .

jogo:alleleNumber
    a owl:DatatypeProperty ;
    rdfs:label "allele number"@en ;
    rdfs:comment "Allele number (AN)."@en ;
    rdfs:domain jogo:Variant ;
    rdfs:range xsd:integer .

jogo:alleleFrequency
    a owl:DatatypeProperty ;
    rdfs:label "allele frequency"@en ;
    rdfs:comment "Allele frequency (AF)."@en ;
    rdfs:domain jogo:Variant ;
    rdfs:range xsd:decimal .

# --- バリアント注釈 (snpEff) ------------------------------------------------
jogo:annotation
    a owl:DatatypeProperty ;
    rdfs:label "annotation"@en ;
    rdfs:comment "snpEff functional annotation (e.g. missense_variant)."@en ;
    rdfs:domain jogo:Variant ;
    rdfs:range xsd:string .

jogo:annotationImpact
    a owl:DatatypeProperty ;
    rdfs:label "annotation impact"@en ;
    rdfs:comment "snpEff annotation impact (HIGH/MODERATE/LOW/MODIFIER)."@en ;
    rdfs:domain jogo:Variant ;
    rdfs:range xsd:string .

jogo:hgvsC
    a owl:DatatypeProperty ;
    rdfs:label "HGVS.c"@en ;
    rdfs:comment "HGVS coding-level notation (snpeff_hgvs_c)."@en ;
    rdfs:domain jogo:Variant ;
    rdfs:range xsd:string .

jogo:hgvsP
    a owl:DatatypeProperty ;
    rdfs:label "HGVS.p"@en ;
    rdfs:comment "HGVS protein-level notation (snpeff_hgvs_p)."@en ;
    rdfs:domain jogo:Variant ;
    rdfs:range xsd:string .
