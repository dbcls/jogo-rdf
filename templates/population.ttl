@prefix jogo:        <http://jogo.csml.org/ontology#> .
@prefix jogo_pop:    <http://jogo.csml.org/rdf/population/> .
@prefix jogo_sample: <http://jogo.csml.org/rdf/sample/> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# JoGo population / super-population — 1000 Genomes Project (IGSR) ベースの参照データ
#   集団 → スーパー集団の対応・サンプル数は JoGo の内訳 (jogo_pop.txt) に準拠。
#   5 super-population + 24 population (うち 23 は標準1000G, USA は JoGo 独自)。
#   jogo:sampleSize は JoGo が当該集団から用いるサンプル(個体)数。
#   rdfs:seeAlso は IGSR data portal の集団ページ (USA を除く)。
#
# 注意: JSON 内の AFR_total 等の super-population 列は標準1000G集計 (USA を含まない)。
#       JoGo の内訳では USA は AFR に属する。集団粒度の頻度から super-population を
#       集約する場合は USA の扱いが JSON 列と一致しない点に留意。
# =============================================================================


# -----------------------------------------------------------------------------
# Super-populations
# -----------------------------------------------------------------------------
jogo_pop:AFR a jogo:SuperPopulation ;
    dcterms:identifier "AFR" ;
    rdfs:label "African"@en ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/AFR> .

jogo_pop:AMR a jogo:SuperPopulation ;
    dcterms:identifier "AMR" ;
    rdfs:label "Admixed American"@en ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/AMR> .

jogo_pop:EAS a jogo:SuperPopulation ;
    dcterms:identifier "EAS" ;
    rdfs:label "East Asian"@en ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/EAS> .

jogo_pop:EUR a jogo:SuperPopulation ;
    dcterms:identifier "EUR" ;
    rdfs:label "European"@en ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/EUR> .

jogo_pop:SAS a jogo:SuperPopulation ;
    dcterms:identifier "SAS" ;
    rdfs:label "South Asian"@en ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/SAS> .


# -----------------------------------------------------------------------------
# Populations — AFR
# -----------------------------------------------------------------------------
jogo_pop:ASW a jogo:Population ;
    dcterms:identifier "ASW" ;
    rdfs:label "Americans of African Ancestry in SW USA"@en ;
    jogo:superPopulation jogo_pop:AFR ;
    jogo:sampleSize 1 ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/ASW> .

# USA: 標準 1000 Genomes の26集団に含まれない JoGo 独自コホート。
#      JoGo の内訳では AFR に分類 (JSON の AFR_total 列には算入されない)。
jogo_pop:USA a jogo:Population ;
    dcterms:identifier "USA" ;
    rdfs:label "USA"@en ;          # TODO: 正式名称・由来コホートを要確認
    jogo:superPopulation jogo_pop:AFR ;
    jogo:sampleSize 2 .

jogo_pop:LWK a jogo:Population ;
    dcterms:identifier "LWK" ;
    rdfs:label "Luhya in Webuye, Kenya"@en ;
    jogo:superPopulation jogo_pop:AFR ;
    jogo:sampleSize 3 ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/LWK> .

jogo_pop:YRI a jogo:Population ;
    dcterms:identifier "YRI" ;
    rdfs:label "Yoruba in Ibadan, Nigeria"@en ;
    jogo:superPopulation jogo_pop:AFR ;
    jogo:sampleSize 3 ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/YRI> .

jogo_pop:MSL a jogo:Population ;
    dcterms:identifier "MSL" ;
    rdfs:label "Mende in Sierra Leone"@en ;
    jogo:superPopulation jogo_pop:AFR ;
    jogo:sampleSize 7 ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/MSL> .

jogo_pop:ESN a jogo:Population ;
    dcterms:identifier "ESN" ;
    rdfs:label "Esan in Nigeria"@en ;
    jogo:superPopulation jogo_pop:AFR ;
    jogo:sampleSize 8 ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/ESN> .

jogo_pop:ACB a jogo:Population ;
    dcterms:identifier "ACB" ;
    rdfs:label "African Caribbeans in Barbados"@en ;
    jogo:superPopulation jogo_pop:AFR ;
    jogo:sampleSize 11 ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/ACB> .

jogo_pop:GWD a jogo:Population ;
    dcterms:identifier "GWD" ;
    rdfs:label "Gambian in Western Divisions in the Gambia"@en ;
    jogo:superPopulation jogo_pop:AFR ;
    jogo:sampleSize 15 ;
    rdfs:seeAlso <https://www.internationalgenome.org/data-portal/population/GWD> .


